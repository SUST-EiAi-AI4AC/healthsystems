        score=#{score},status=#{status}
        where user_id=#{userId} and log_date=#{logDate}
    </update>

    <select id="getListByPage" resultType="com.nwpu.healthsystem.backend.entity.scale.Scl90">
        select * from scl90 where user_id=#{userId} order by id desc
    </select>

    <select id="getToday" resultType="int">
        select count(0) from scl90 where user_id=#{userId} and log_date=#{date}
    </select>

    <select id="getRecentInput" resultType="com.nwpu.healthsystem.backend.entity.scale.Scl90">
        select * from scl90
        where user_id=#{userId}
        order by log_date desc limit 1
    </select>
</mapper>
